# Variables comunes de entorno para Docker Compose

# Configuración de Base de Datos PostgreSQL
DB_CONNECTION=pgsql
DB_DATABASE=nexus_db
DB_USERNAME=nexus_user
DB_PASSWORD=nexus_password

# Configuración del Backend (Laravel)
APP_NAME=NexusLab
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Configuración del Frontend (Vue)
# NOTA: En la etapa de build, las variables que necesita Vue usualmente 
# deben estar disponibles. Si Vite requiere acceder a la API, puedes usar esta variable:
VITE_API_URL=http://localhost:8000/api
