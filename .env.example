# Variables comunes de entorno para Docker Compose

# Configuración de Base de Datos PostgreSQL
DB_CONNECTION=pgsql
DB_DATABASE=nexus_db
DB_USERNAME=nexus_user
DB_PASSWORD=nexus_password

# Configuración del Backend (Laravel)
APP_NAME=NexusLab
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Configuración del Frontend (Vue)
# NOTA: En la etapa de build, las variables que necesita Vue usualmente 
# deben estar disponibles. Si Vite requiere acceder a la API, puedes usar esta variable:
VITE_API_URL=http://localhost:8000/api

# ==========================================
# Configuración Interna de Laravel (Backend)
# ==========================================
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# Configuración de Correo Electrónico (Para usar en Hostinger)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="admin@tudominio.com"
MAIL_FROM_NAME="${APP_NAME}"

# Configuración de WebSockets (Reverb)
REVERB_APP_ID=997146
REVERB_APP_KEY=540ubcgeqeb3gaisx7vy
REVERB_APP_SECRET=zkziwmgcdenae4tjibcs
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http
